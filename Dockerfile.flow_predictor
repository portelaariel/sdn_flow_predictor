# FlowPredictor (CNSM) — Predição de vazão + detecção de anomalias
# Build:  docker build -t flow_predictor_cnsm -f Dockerfile.flow_predictor .

FROM python:3.9-slim

RUN pip install --no-cache-dir \
    Flask==2.0.3 \
    Werkzeug==2.0.1 \
    requests==2.28.1 \
    etcd3==0.12.0 \
    protobuf==3.20.3

WORKDIR /app
COPY flow_predictor_cnsm.py /app/

# Porta HTTP padrão do serviço (sobrescrita via -e PORT no run)
EXPOSE 6060

CMD ["python3", "flow_predictor_cnsm.py"]
